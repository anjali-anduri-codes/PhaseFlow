# Google OAuth Configuration
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/google/callback

# Backend API Configuration
VITE_API_BASE_URL=http://localhost:5173

# Demo/testing flag for cycle records returned from Google Fit sync
# true = cycle data found, false = no cycle data found
VITE_GOOGLE_FIT_HAS_CYCLE_DATA=false

# Backend Environment Variables (Vercel / Serverless)
# Set these in your serverless platform's environment settings, NOT in .env.local
# GOOGLE_CLIENT_SECRET=
# GEMMA_API_KEY=
# GEMMA_MODEL=gemma-4-31b-it
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local frontend Gemma mode (optional)
# If set, the app can call Google Generative Language API directly from the browser.
# Use referrer-restricted keys for safety.
# VITE_GEMMA_API_KEY=
# VITE_GEMMA_LOCAL_MODEL=gemma-4-31b-it
# VITE_GEMMA_LOCAL_ONLY=false